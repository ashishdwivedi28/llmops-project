# --- LLMOps Backend Configuration ---

# 1. Google Cloud Configuration (Required for Vertex AI/Gemini/RAG)
GOOGLE_CLOUD_PROJECT=search-ahmed
GOOGLE_CLOUD_LOCATION=us-central1
# Optional: Usually same as GOOGLE_CLOUD_PROJECT
BIGQUERY_PROJECT=search-ahmed
FIRESTORE_PROJECT=search-ahmed
RAG_LOCATION=us-central1

# 2. Non-Google LLM Providers (LiteLLM Integration)
# Add your API keys here to use models like Claude or GPT
ANTHROPIC_API_KEY=sk-ant-xxx...
OPENAI_API_KEY=sk-xxx...
XAI_API_KEY=xai-xxx...
# Optional: Add other providers as needed (Mistral, Groq, etc.)
# MISTRAL_API_KEY=...
# GROQ_API_KEY=...

# 3. Observability & Logging
LOG_LEVEL=DEBUG
# Set to true to see full LiteLLM debugging logs in terminal
LITELLM_LOG=DEBUG

# 4. Server Configuration
HOST=127.0.0.1
PORT=8000

# 5. Local Authentication (for Local Development)
# Path to your Google Cloud Service Account JSON key (if not using gcloud auth application-default login)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json
